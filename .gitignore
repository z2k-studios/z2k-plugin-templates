# vscode
.vscode

# Intellij
*.iml
.idea

# npm
node_modules

# Don't include the compiled main.js file in the repo.
# They should be uploaded to GitHub releases instead.
main.js

# Production build output (separate from dev watcher to avoid contention)
release/

# Exclude the zip file of the plugin too
*.zip

# Exclude sourcemaps
*.map

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Output Logs
*.log

# VS Code Workspace Settings
*.code-workspace

# Obsidian
**/.obsidian/
