# vscode
.vscode

# Intellij
*.iml
.idea

# npm
node_modules

# Build outputs. dev/ holds the watcher output (used by the testing vault sync);
# release/ holds the production build (uploaded to GitHub releases).
# Neither is committed — release artifacts get attached on tag push.
dev/
release/

# Exclude the zip file of the plugin too
*.zip

# Exclude sourcemaps
*.map

# Exclude macOS Finder (System Explorer) View States
.DS_Store

# Output Logs
*.log

# VS Code Workspace Settings
*.code-workspace

# Obsidian
**/.obsidian/
